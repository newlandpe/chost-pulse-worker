{
  "name": "chost-pulse-worker",
  "version": "1.0.0",
  "description": "Multi-platform serverless worker for game server monitoring",
  "scripts": {
    "dev:cf": "wrangler dev src/platforms/cloudflare.ts",
    "dev:vercel": "vercel dev",
    "dev:netlify": "netlify dev",
    "build:bundle": "esbuild api/index.ts --bundle --format=esm --outfile=dist/index.js --platform=node --external:ioredis",
    "test": "vitest run"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.10",
    "badge-maker": "^6.0.0",
    "esbuild": "^0.28.0",
    "hono": "^4.12.30",
    "ioredis": "^5.11.1",
    "simple-icons": "^16.25.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.6",
    "@cloudflare/workers-types": "^5.20260713.1",
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10",
    "wrangler": "^4.103.0"
  }
}
