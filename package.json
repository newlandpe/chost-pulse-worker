{
  "name": "chost-pulse-worker",
  "version": "1.0.0",
  "description": "Multi-platform serverless worker for game server monitoring",
  "scripts": {
    "dev:cf": "wrangler dev src/platforms/cloudflare.ts",
    "dev:vercel": "vercel dev",
    "dev:netlify": "netlify dev",
    "build:bundle": "esbuild api/index.ts --bundle --format=esm --outfile=dist/index.js --platform=node --external:ioredis",
    "test": "vitest run"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "badge-maker": "^5.0.2",
    "esbuild": "^0.28.0",
    "hono": "^4.12.11",
    "ioredis": "^5.10.1",
    "simple-icons": "^16.16.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.14.7",
    "@cloudflare/workers-types": "^4.20260405.1",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4",
    "wrangler": "^4.83.0"
  }
}
